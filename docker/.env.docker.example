# ============================================================
# TEIR - Variables de Entorno para Docker
# ============================================================
# IMPORTANTE: Copia este archivo como .env y cambia las
# contraseñas antes de usar en producción.
#
# Uso: cp .env.docker .env
# ============================================================

# ---- Django ----
DJANGO_SECRET_KEY=CHANGE_ME__GENERATE_A_REAL_SECRET_KEY
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ---- Base de Datos MySQL ----
DB_NAME=tem_dbv2
DB_USER=teir_user
DB_PASSWORD=CHANGE_ME__SET_A_REAL_PASSWORD
DB_HOST=db
DB_PORT=3306
MYSQL_ROOT_PASSWORD=CHANGE_ME__SET_A_REAL_ROOT_PASSWORD

